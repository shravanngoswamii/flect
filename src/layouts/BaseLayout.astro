---
import "../styles/global.css";
import { siteConfig } from "../config";
import { navGroups, quickLinks } from "../data/navigation";
import Logo from "../components/Logo.astro";
import Search from "../components/Search.astro";
import GitHubIcon from "../components/icons/GitHubIcon.astro";
import HeartIcon from "../components/icons/HeartIcon.astro";
import { withBase } from "../lib/paths";

interface Props {
	title?: string;
	description?: string;
	bodyClass?: string;
	noindex?: boolean;
	canonical?: string;
	ogType?: "website" | "article";
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
	title = siteConfig.name,
	description = siteConfig.tagline,
	bodyClass = "",
	noindex = false,
	canonical,
	ogType = "website",
	structuredData,
} = Astro.props;
const pageTitle =
	title === siteConfig.name ? siteConfig.name : `${title} | ${siteConfig.name}`;
const githubSponsorsUrl = siteConfig.githubSponsorsUrl;
const canonicalUrl = (() => {
	const candidate = canonical ?? Astro.url.href;
	const url = new URL(candidate, Astro.site ?? Astro.url);
	url.search = "";
	url.hash = "";
	return url.href;
})();
const ogImageUrl = new URL(withBase("/og.png"), Astro.site ?? Astro.url).href;
const defaultStructuredData = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: pageTitle,
	description,
	url: canonicalUrl,
};
const extraStructuredData = Array.isArray(structuredData)
	? structuredData
	: structuredData
		? [structuredData]
		: [];
const jsonLdItems = [defaultStructuredData, ...extraStructuredData];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content={siteConfig.name} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="theme-color" content={siteConfig.themeColor.light} media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content={siteConfig.themeColor.dark} media="(prefers-color-scheme: dark)" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<!-- Umami Analytics — set PUBLIC_UMAMI_WEBSITE_ID to enable, see src/config.ts -->
		{siteConfig.umami.websiteId && (
			<script defer src={siteConfig.umami.src} data-website-id={siteConfig.umami.websiteId}></script>
		)}
		{jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)}></script>)}
		<title>{pageTitle}</title>
		<script is:inline>
			(() => {
				const key = 'theme';
				const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
				const stored = localStorage.getItem(key);
				document.documentElement.dataset.theme = stored || preferred;
			})();
		</script>
	</head>
	<body class={bodyClass}>
		<header class="site-header" data-pagefind-ignore>
			<a class="brand" href={withBase('/')} aria-label={`${siteConfig.name} home`}>
				<Logo />
				<span>{siteConfig.name}</span>
			</a>
			<Search />
			<nav class="top-nav" aria-label="Main navigation">
				<a href={withBase('/docs/')}>Docs</a>
				<a href={withBase('/blog/')}>Blog</a>
				<a href={withBase(navGroups[0].items[0].href)}>Get Started</a>
				{githubSponsorsUrl && (
					<a class="nav-heart" href={githubSponsorsUrl} target="_blank">
						<HeartIcon />
						Support
					</a>
				)}
				<a class="icon-link" href={siteConfig.githubUrl} aria-label="GitHub repository" target="_blank">
					<GitHubIcon />
					<span>GitHub</span>
				</a>
			</nav>
			<button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle dark mode">
				<svg class="sun-icon" aria-hidden="true" viewBox="0 0 24 24">
					<path d="M12 17.2a5.2 5.2 0 1 0 0-10.4 5.2 5.2 0 0 0 0 10.4Zm0-14.7a1 1 0 0 1 1 1v1.2a1 1 0 1 1-2 0V3.5a1 1 0 0 1 1-1Zm0 16.8a1 1 0 0 1 1 1v1.2a1 1 0 1 1-2 0v-1.2a1 1 0 0 1 1-1Zm9.5-8.3a1 1 0 1 1 0 2h-1.2a1 1 0 1 1 0-2h1.2ZM4.7 11a1 1 0 1 1 0 2H3.5a1 1 0 1 1 0-2h1.2Zm13.74-6.44a1 1 0 0 1 0 1.42l-.85.85a1 1 0 0 1-1.42-1.42l.85-.85a1 1 0 0 1 1.42 0ZM7.83 16.17a1 1 0 0 1 0 1.42l-.85.85a1 1 0 0 1-1.42-1.42l.85-.85a1 1 0 0 1 1.42 0Zm9.76 0 .85.85a1 1 0 1 1-1.42 1.42l-.85-.85a1 1 0 0 1 1.42-1.42ZM6.98 4.56l.85.85a1 1 0 0 1-1.42 1.42l-.85-.85a1 1 0 1 1 1.42-1.42Z" />
				</svg>
				<svg class="moon-icon" aria-hidden="true" viewBox="0 0 24 24">
					<path d="M21 14.58A8.2 8.2 0 0 1 9.42 3a9.25 9.25 0 1 0 11.59 11.59Z" />
				</svg>
			</button>
			<button class="mobile-menu-toggle" type="button" data-mobile-menu-toggle aria-label="Open menu" aria-expanded="false">
				<svg class="mobile-menu-icon" aria-hidden="true" viewBox="0 0 24 24">
					<path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" />
				</svg>
				<svg class="mobile-close-icon" aria-hidden="true" viewBox="0 0 24 24">
					<path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" />
				</svg>
			</button>
			<div class="mobile-menu" data-mobile-menu>
				<div class="mobile-menu-card">
					<div class="mobile-menu-head">
						<span>Menu</span>
						<button type="button" data-mobile-search-open aria-label="Search documentation">
							<svg aria-hidden="true" viewBox="0 0 24 24">
								<path d="m20 20-4.35-4.35m2.35-5.15a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" />
							</svg>
						</button>
					</div>
					<a href={withBase('/docs/')}>Docs</a>
					<a href={withBase('/blog/')}>Blog</a>
					<a href={withBase(navGroups[0].items[0].href)}>Get Started</a>
					<a href={siteConfig.githubUrl} target="_blank">
						<GitHubIcon />
						GitHub
					</a>
					{githubSponsorsUrl && (
						<a class="nav-heart" href={githubSponsorsUrl} target="_blank">
							<HeartIcon />
							Support
						</a>
					)}
				</div>
			</div>
		</header>
		<div class="mobile-backdrop" data-mobile-backdrop data-pagefind-ignore></div>
		<main data-pagefind-body>
			<slot />
		</main>
		<footer class="site-footer" data-pagefind-ignore>
			<div class="footer-divider"></div>
			<div class="footer-inner">
				<div class="footer-brand">
					<Logo class="footer-logo" />
					<strong>{siteConfig.name}</strong>
					<span>{siteConfig.tagline}</span>
				</div>
				<nav class="footer-nav" aria-label="Footer navigation">
					{quickLinks.slice(0, 4).map((link) => <a href={withBase(link.href)}>{link.title}</a>)}
				</nav>
				<div class="footer-actions">
					<a href={withBase('/blog/')}>Blog</a>
					{githubSponsorsUrl && (
						<a class="nav-heart" href={githubSponsorsUrl} target="_blank">
							<HeartIcon />
							Support
						</a>
					)}
					<a class="icon-link" href={siteConfig.githubUrl} target="_blank">
						<GitHubIcon />
						GitHub
					</a>
				</div>
				<p class="footer-meta">
					&copy; {new Date().getFullYear()} {siteConfig.name}
				</p>
			</div>
		</footer>
		<script is:inline>
			(() => {
				const key = 'theme';
				const root = document.documentElement;
				const button = document.querySelector('[data-theme-toggle]');
				const apply = (theme) => {
					root.dataset.theme = theme;
					button?.setAttribute('aria-pressed', String(theme === 'dark'));
				};

				button?.addEventListener('click', () => {
					const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
					localStorage.setItem(key, next);
					apply(next);
				});

				apply(root.dataset.theme || 'light');
			})();

			(() => {
				const blocks = document.querySelectorAll('main pre');
				for (const pre of blocks) {
					if (pre.closest('.prompt-player') || pre.parentElement?.classList.contains('code-frame')) {
						continue;
					}

					const frame = document.createElement('div');
					frame.className = 'code-frame';
					const button = document.createElement('button');
					button.className = 'copy-code-button';
					button.type = 'button';
					button.textContent = 'Copy';
					button.setAttribute('aria-label', 'Copy code block');

					pre.parentNode?.insertBefore(frame, pre);
					frame.append(pre, button);

					button.addEventListener('click', async () => {
						const text = pre.textContent || '';
						try {
							await navigator.clipboard.writeText(text);
							button.textContent = 'Copied';
							window.setTimeout(() => {
								button.textContent = 'Copy';
							}, 1300);
						} catch {
							button.textContent = 'Failed';
							window.setTimeout(() => {
								button.textContent = 'Copy';
							}, 1300);
						}
					});
				}
			})();

			(() => {
				const header = document.querySelector('.site-header');
				if (!header) return;
				let lastY = window.scrollY;
				let ticking = false;

				const update = () => {
					const y = window.scrollY;
					if (header.classList.contains('menu-open')) {
						lastY = y;
						ticking = false;
						return;
					}
					if (y <= 60) {
						header.classList.remove('header-hidden');
					} else if (y > lastY) {
						header.classList.add('header-hidden');
					} else {
						header.classList.remove('header-hidden');
					}
					lastY = y;
					ticking = false;
				};

				window.addEventListener('scroll', () => {
					if (!ticking) {
						requestAnimationFrame(update);
						ticking = true;
					}
				}, { passive: true });
			})();

			(() => {
				const header = document.querySelector('.site-header');
				const toggle = document.querySelector('[data-mobile-menu-toggle]');
				const backdrop = document.querySelector('[data-mobile-backdrop]');
				const menu = document.querySelector('[data-mobile-menu]');
				const search = document.querySelector('[data-mobile-search-open]');
				const closeMenu = () => {
					header?.classList.remove('menu-open');
					toggle?.setAttribute('aria-expanded', 'false');
				};
				const openMenu = () => {
					header?.classList.add('menu-open');
					toggle?.setAttribute('aria-expanded', 'true');
				};

				toggle?.addEventListener('click', () => {
					header?.classList.contains('menu-open') ? closeMenu() : openMenu();
				});
				backdrop?.addEventListener('click', closeMenu);
				menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
				search?.addEventListener('click', () => {
					closeMenu();
					document.dispatchEvent(new CustomEvent('docs:open-search'));
				});
				document.addEventListener('keydown', (event) => {
					if (event.key === 'Escape') closeMenu();
				});
			})();


		</script>
	</body>
</html>
