---
import { siteConfig } from "../config";
import { logoMark } from "../assets/logoMark";

interface Props {
	class?: string;
}

const className = Astro.props.class ?? "logo-mark";
---

<svg class={className} viewBox={logoMark.viewBox} role="img" aria-label={siteConfig.name}>
	<path
		d={logoMark.spine}
		fill="none"
		stroke="currentColor"
		stroke-width={logoMark.strokeWidth}
		stroke-linecap="round"
	/>
	<path
		d={logoMark.topArm}
		fill="none"
		stroke="currentColor"
		stroke-width={logoMark.strokeWidth}
		stroke-linecap="round"
	/>
	<path
		d={logoMark.middleArm}
		fill="none"
		stroke="currentColor"
		stroke-width={logoMark.strokeWidth}
		stroke-linecap="round"
	/>
	<path
		d={logoMark.bend}
		fill="none"
		stroke="var(--logo-accent)"
		stroke-width={logoMark.strokeWidth}
		stroke-linecap="round"
	/>
	<circle cx={logoMark.dot.cx} cy={logoMark.dot.cy} r={logoMark.dot.r} fill="var(--logo-warn)" />
</svg>
