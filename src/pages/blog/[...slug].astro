---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";
import { getReadingTime } from "../../utils/readingTime";

type Post = CollectionEntry<"blog">;

interface PagerLink {
	id: string;
	title: string;
}

interface RelatedPost {
	id: string;
	title: string;
	pubDate: Date;
}

export async function getStaticPaths() {
	const posts = (await getCollection("blog")).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

	return posts.map((post, index) => {
		const prevPost = index > 0 ? posts[index - 1] : undefined;
		const nextPost = index < posts.length - 1 ? posts[index + 1] : undefined;

		const currentTags = post.data.tags ?? [];
		const others = posts.filter((candidate) => candidate.id !== post.id);

		const sharedTagCount = (candidate: Post) => {
			if (currentTags.length === 0 || !candidate.data.tags) return 0;
			return candidate.data.tags.filter((tag) => currentTags.includes(tag))
				.length;
		};

		const rankedByTag = others
			.map((candidate) => ({ candidate, shared: sharedTagCount(candidate) }))
			.filter((entry) => entry.shared > 0)
			.sort((a, b) => {
				if (b.shared !== a.shared) return b.shared - a.shared;
				return (
					b.candidate.data.pubDate.valueOf() -
					a.candidate.data.pubDate.valueOf()
				);
			})
			.map((entry) => entry.candidate);

		// others is already sorted by recency (descending pubDate), same as posts,
		// so it doubles as the "most recent" fallback when nothing shares a tag.
		const relatedSource = rankedByTag.length > 0 ? rankedByTag : others;
		const relatedPosts: RelatedPost[] = relatedSource
			.slice(0, 3)
			.map((related) => ({
				id: related.id,
				title: related.data.title,
				pubDate: related.data.pubDate,
			}));

		return {
			params: { slug: post.id },
			props: {
				post,
				prevPost: prevPost
					? { id: prevPost.id, title: prevPost.data.title }
					: undefined,
				nextPost: nextPost
					? { id: nextPost.id, title: nextPost.data.title }
					: undefined,
				relatedPosts,
			},
		};
	});
}

interface Props {
	post: Post;
	prevPost?: PagerLink;
	nextPost?: PagerLink;
	relatedPosts: RelatedPost[];
}

const { post, prevPost, nextPost, relatedPosts } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body ?? "");
---

<BlogPost
	frontmatter={post.data}
	headings={headings}
	readingTime={readingTime}
	prevPost={prevPost}
	nextPost={nextPost}
	relatedPosts={relatedPosts}
>
	<Content />
</BlogPost>
