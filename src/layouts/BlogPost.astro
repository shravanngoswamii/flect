---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ShareLinks from "../components/ShareLinks.astro";
import BackToTop from "../components/BackToTop.astro";
import { withBase } from "../lib/paths";
import { slugifyTag } from "../utils/slug";
import type { ReadingTime } from "../utils/readingTime";

type BlogData = CollectionEntry<"blog">["data"];

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface PagerLink {
	id: string;
	title: string;
}

interface RelatedPost {
	id: string;
	title: string;
	pubDate: Date;
}

interface Props {
	frontmatter: BlogData;
	headings?: Heading[];
	readingTime: ReadingTime;
	prevPost?: PagerLink;
	nextPost?: PagerLink;
	relatedPosts?: RelatedPost[];
}

const {
	frontmatter,
	headings = [],
	readingTime,
	prevPost,
	nextPost,
	relatedPosts = [],
} = Astro.props;
const { title, description, pubDate, updatedDate, tags, heroImage } =
	frontmatter;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

const relatedDateFormatter = new Intl.DateTimeFormat("en-US", {
	year: "numeric",
	month: "short",
	day: "numeric",
});

// TableOfContents.astro applies this same filter itself; computed here too so
// we know whether to render the surrounding panel/sidebar chrome at all.
const tocHeadings = headings.filter(
	(heading) => heading.depth >= 2 && heading.depth <= 3,
);
const hasToc = tocHeadings.length > 0;
---

<BaseLayout title={title} description={description} bodyClass="blog-page" ogType="article">
	<article class="blog-post">
		<a class="blog-back" href={withBase("/blog/")}>
			<svg aria-hidden="true" viewBox="0 0 24 24">
				<path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
			Back to blog
		</a>

		{
			heroImage && (
				<figure class="blog-post-hero">
					{typeof heroImage === "string" ? (
						<img src={heroImage} alt={title} loading="eager" />
					) : (
						<Image
							src={heroImage}
							alt={title}
							widths={[480, 768, 1024, 1600]}
							sizes="(min-width: 860px) 70rem, 100vw"
						/>
					)}
				</figure>
			)
		}

		<div class:list={["blog-post-shell", { "no-toc": !hasToc }]}>
			<div class="blog-post-content">
				<header class="blog-post-header">
					<h1>{title}</h1>
					<div class="blog-post-meta">
						<time datetime={pubDate.toISOString()}>{dateFormatter.format(pubDate)}</time>
						{updatedDate && (
							<span class="blog-updated">
								Updated <time datetime={updatedDate.toISOString()}>{dateFormatter.format(updatedDate)}</time>
							</span>
						)}
						<span class="blog-reading-time">{readingTime.minutes} min read</span>
						{tags && tags.length > 0 && (
							<ul class="blog-tags">
								{tags.map((tag) => (
									<li>
										<a href={withBase(`/blog/tags/${slugifyTag(tag)}/`)}>{tag}</a>
									</li>
								))}
							</ul>
						)}
					</div>
					<p class="blog-post-description">{description}</p>
				</header>

				{hasToc && (
					<details class="docs-panel blog-toc-panel" data-pagefind-ignore>
						<summary>On this page</summary>
						<TableOfContents headings={headings} />
					</details>
				)}

				<div class="prose">
					<slot />
				</div>

				{relatedPosts.length > 0 && (
					<section class="blog-related" aria-label="Related posts">
						<h2>Related posts</h2>
						<ul class="blog-related-list">
							{relatedPosts.map((related) => (
								<li>
									<a class="blog-related-link" href={withBase(`/blog/${related.id}/`)}>
										<span class="blog-related-title">{related.title}</span>
										<time class="blog-related-date" datetime={related.pubDate.toISOString()}>
											{relatedDateFormatter.format(related.pubDate)}
										</time>
									</a>
								</li>
							))}
						</ul>
					</section>
				)}

				<ShareLinks title={title} />

				<nav class="docs-pager blog-post-pager" aria-label="Blog post pagination">
					{prevPost ? (
						<a class="docs-pager-link docs-pager-prev" href={withBase(`/blog/${prevPost.id}/`)}>
							<svg aria-hidden="true" viewBox="0 0 24 24"><path d="M15 6l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
							<span class="docs-pager-text">
								<span class="docs-pager-label">Previous</span>
								<span class="docs-pager-title">{prevPost.title}</span>
							</span>
						</a>
					) : (
						<span class="docs-pager-placeholder" />
					)}
					{nextPost ? (
						<a class="docs-pager-link docs-pager-next" href={withBase(`/blog/${nextPost.id}/`)}>
							<span class="docs-pager-text">
								<span class="docs-pager-label">Next</span>
								<span class="docs-pager-title">{nextPost.title}</span>
							</span>
							<svg aria-hidden="true" viewBox="0 0 24 24"><path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
						</a>
					) : (
						<span class="docs-pager-placeholder" />
					)}
				</nav>
			</div>

			{hasToc && <TableOfContents headings={headings} />}
		</div>
	</article>

	<BackToTop />
</BaseLayout>
