---
import type { GetStaticPaths } from "astro";
import { type CollectionEntry, getCollection } from "astro:content";
import BlogCard from "../../../components/BlogCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { siteConfig } from "../../../config";
import { withBase } from "../../../lib/paths";
import { getReadingTime } from "../../../utils/readingTime";
import { slugifyTag } from "../../../utils/slug";

export const getStaticPaths = (async () => {
	const posts = await getCollection("blog");

	// Dedupe tags by their exact (case-sensitive) original string first, then
	// slugify. Two differently-cased tags that collide on slug share a page,
	// keeping the first-seen original string as the display label.
	const uniqueTags = new Set<string>();
	for (const post of posts) {
		for (const tag of post.data.tags ?? []) {
			uniqueTags.add(tag);
		}
	}

	const slugToLabel = new Map<string, string>();
	for (const tag of uniqueTags) {
		const slug = slugifyTag(tag);
		if (!slugToLabel.has(slug)) slugToLabel.set(slug, tag);
	}

	return Array.from(slugToLabel.entries()).map(([slug, label]) => {
		const matchingPosts = posts
			.filter((post) => post.data.tags?.some((tag) => slugifyTag(tag) === slug))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

		return {
			params: { tag: slug },
			props: { tagLabel: label, posts: matchingPosts },
		};
	});
}) satisfies GetStaticPaths;

interface Props {
	tagLabel: string;
	posts: CollectionEntry<"blog">[];
}

const { tagLabel, posts } = Astro.props;
const postCount = posts.length;
---

<BaseLayout
	title={`Posts tagged "${tagLabel}"`}
	description={`${postCount} ${postCount === 1 ? "post" : "posts"} tagged "${tagLabel}" on the ${siteConfig.name} blog.`}
>
	<section class="blog-index">
		<header class="blog-index-header">
			<a class="blog-back" href={withBase("/blog/")}>
				<svg aria-hidden="true" viewBox="0 0 24 24">
					<path
						d="M15 18l-6-6 6-6"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					/>
				</svg>
				Back to blog
			</a>
			<h1>Posts tagged "{tagLabel}"</h1>
		</header>
		{
			posts.length > 0 ? (
				<div class="blog-list">
					{posts.map((post) => (
						<BlogCard
							href={withBase(`/blog/${post.id}/`)}
							title={post.data.title}
							description={post.data.description}
							pubDate={post.data.pubDate}
							tags={post.data.tags}
							heroImage={post.data.heroImage}
							readingMinutes={getReadingTime(post.body ?? "").minutes}
						/>
					))}
				</div>
			) : (
				<p>No posts tagged "{tagLabel}" yet.</p>
			)
		}
	</section>
</BaseLayout>
