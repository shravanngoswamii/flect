---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../config";
import { withBase } from "../../lib/paths";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
---

<BaseLayout
	title="Blog"
	description={`Announcements, guides, and notes on building ${siteConfig.name}.`}
>
	<section class="blog-index">
		<header class="blog-index-header">
			<h1>Blog</h1>
			<p>Announcements, guides, and the thinking behind {siteConfig.name} — written the same way the docs are.</p>
		</header>
		<div class="blog-grid">
			{
				posts.map((post) => (
					<a class="blog-card" href={withBase(`/blog/${post.id}/`)}>
						<time datetime={post.data.pubDate.toISOString()}>
							{dateFormatter.format(post.data.pubDate)}
						</time>
						<h2>{post.data.title}</h2>
						<p>{post.data.description}</p>
						{post.data.tags && post.data.tags.length > 0 && (
							<ul class="blog-tags">
								{post.data.tags.map((tag) => (
									<li>{tag}</li>
								))}
							</ul>
						)}
					</a>
				))
			}
		</div>
	</section>
</BaseLayout>
