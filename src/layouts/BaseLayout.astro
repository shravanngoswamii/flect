---
import "../styles/global.css";
import { siteConfig } from "../config";
import { navGroups, quickLinks } from "../data/navigation";
import Logo from "../components/Logo.astro";
import Search from "../components/Search.astro";
import GitHubIcon from "../components/icons/GitHubIcon.astro";
import HeartIcon from "../components/icons/HeartIcon.astro";
import { withBase } from "../lib/paths";
import { THEMES, buildThemesCss } from "../utils/themes";

interface Props {
	title?: string;
	description?: string;
	bodyClass?: string;
	noindex?: boolean;
	canonical?: string;
	ogType?: "website" | "article";
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
	title = siteConfig.name,
	description = siteConfig.tagline,
	bodyClass = "",
	noindex = false,
	canonical,
	ogType = "website",
	structuredData,
} = Astro.props;
const pageTitle =
	title === siteConfig.name ? siteConfig.name : `${title} | ${siteConfig.name}`;
const githubSponsorsUrl = siteConfig.githubSponsorsUrl;
const canonicalUrl = (() => {
	const candidate = canonical ?? Astro.url.href;
	const url = new URL(candidate, Astro.site ?? Astro.url);
	url.search = "";
	url.hash = "";
	return url.href;
})();
const ogImageUrl = new URL(withBase("/og.png"), Astro.site ?? Astro.url).href;
const defaultStructuredData = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: pageTitle,
	description,
	url: canonicalUrl,
};
const extraStructuredData = Array.isArray(structuredData)
	? structuredData
	: structuredData
		? [structuredData]
		: [];
const jsonLdItems = [defaultStructuredData, ...extraStructuredData];
const themesCss = buildThemesCss();
const lightThemes = THEMES.filter((t) => t.mode === "light");
const darkThemes = THEMES.filter((t) => t.mode === "dark");
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content={siteConfig.name} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="theme-color" content={siteConfig.themeColor.light} media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content={siteConfig.themeColor.dark} media="(prefers-color-scheme: dark)" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<!-- Umami Analytics — set PUBLIC_UMAMI_WEBSITE_ID to enable, see src/config.ts -->
		{siteConfig.umami.websiteId && (
			<script defer src={siteConfig.umami.src} data-website-id={siteConfig.umami.websiteId}></script>
		)}
		{jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)}></script>)}
		<title>{pageTitle}</title>
		<style set:html={themesCss}></style>
		<script is:inline>
			(() => {
				const key = 'theme';
				const legacyMap = { light: 'flect-light', dark: 'flect-dark' };
				let stored = localStorage.getItem(key);
				if (stored && legacyMap[stored]) {
					stored = legacyMap[stored];
					localStorage.setItem(key, stored);
				}
				const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const isSystem = !stored || stored === 'system';
				const resolved = isSystem ? (systemDark ? 'flect-dark' : 'flect-light') : stored;
				const mode = resolved.endsWith('-dark') ? 'dark' : 'light';
				const root = document.documentElement;
				root.dataset.mode = mode;
				root.dataset.theme = resolved;
			})();
		</script>
	</head>
	<body class={bodyClass}>
		<header class="site-header" data-pagefind-ignore>
			<a class="brand" href={withBase('/')} aria-label={`${siteConfig.name} home`}>
				<Logo />
				<span>{siteConfig.name}</span>
			</a>
			<Search />
			<nav class="top-nav" aria-label="Main navigation">
				<a href={withBase('/docs/')}>Docs</a>
				<a href={withBase('/blog/')}>Blog</a>
				<a href={withBase(navGroups[0].items[0].href)}>Get Started</a>
				{githubSponsorsUrl && (
					<a class="nav-heart" href={githubSponsorsUrl} target="_blank">
						<HeartIcon />
						Support
					</a>
				)}
				<a class="icon-link" href={siteConfig.githubUrl} aria-label="GitHub repository" target="_blank">
					<GitHubIcon />
					<span>GitHub</span>
				</a>
			</nav>
			<div class="theme-picker" data-theme-picker>
				<button class="theme-toggle" type="button" data-theme-quick-toggle aria-label="Toggle dark mode">
					<svg class="sun-icon" aria-hidden="true" viewBox="0 0 24 24">
						<path d="M12 17.2a5.2 5.2 0 1 0 0-10.4 5.2 5.2 0 0 0 0 10.4Zm0-14.7a1 1 0 0 1 1 1v1.2a1 1 0 1 1-2 0V3.5a1 1 0 0 1 1-1Zm0 16.8a1 1 0 0 1 1 1v1.2a1 1 0 1 1-2 0v-1.2a1 1 0 0 1 1-1Zm9.5-8.3a1 1 0 1 1 0 2h-1.2a1 1 0 1 1 0-2h1.2ZM4.7 11a1 1 0 1 1 0 2H3.5a1 1 0 1 1 0-2h1.2Zm13.74-6.44a1 1 0 0 1 0 1.42l-.85.85a1 1 0 0 1-1.42-1.42l.85-.85a1 1 0 0 1 1.42 0ZM7.83 16.17a1 1 0 0 1 0 1.42l-.85.85a1 1 0 0 1-1.42-1.42l.85-.85a1 1 0 0 1 1.42 0Zm9.76 0 .85.85a1 1 0 1 1-1.42 1.42l-.85-.85a1 1 0 0 1 1.42-1.42ZM6.98 4.56l.85.85a1 1 0 0 1-1.42 1.42l-.85-.85a1 1 0 1 1 1.42-1.42Z" />
					</svg>
					<svg class="moon-icon" aria-hidden="true" viewBox="0 0 24 24">
						<path d="M21 14.58A8.2 8.2 0 0 1 9.42 3a9.25 9.25 0 1 0 11.59 11.59Z" />
					</svg>
				</button>
				<button class="theme-caret" type="button" data-theme-menu-toggle aria-haspopup="menu" aria-expanded="false" aria-label="Choose theme">
					<svg aria-hidden="true" viewBox="0 0 24 24">
						<path d="m6 9 6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>
				<div class="theme-popover" data-theme-popover role="menu" aria-label="Themes" hidden>
					<div class="theme-segment" role="group" aria-label="Appearance">
						<button type="button" class="theme-segment-btn" data-theme-segment="system">System</button>
						<button type="button" class="theme-segment-btn" data-theme-segment="light">Light</button>
						<button type="button" class="theme-segment-btn" data-theme-segment="dark">Dark</button>
					</div>
					<div class="theme-grid" data-mode-grid="light">
						{lightThemes.map((t) => (
							<button
								type="button"
								class="theme-tile"
								role="menuitemradio"
								data-theme-id={t.id}
								style={`--tile-bg:${t.bg};--tile-surface:${t.surface};--tile-text:${t.text};--tile-accent:${t.swatch}`}
							>
								<span class="theme-tile-preview" aria-hidden="true">
									<span class="theme-tile-card">
										<span class="theme-tile-bar"></span>
										<span class="theme-tile-line"></span>
										<span class="theme-tile-line theme-tile-line-short"></span>
									</span>
								</span>
								<span class="theme-tile-row">
									<span class="theme-tile-name">{t.name}</span>
									<svg class="theme-tile-check" aria-hidden="true" viewBox="0 0 24 24">
										<path d="M20 6 9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
									</svg>
								</span>
							</button>
						))}
					</div>
					<div class="theme-grid" data-mode-grid="dark" hidden>
						{darkThemes.map((t) => (
							<button
								type="button"
								class="theme-tile"
								role="menuitemradio"
								data-theme-id={t.id}
								style={`--tile-bg:${t.bg};--tile-surface:${t.surface};--tile-text:${t.text};--tile-accent:${t.swatch}`}
							>
								<span class="theme-tile-preview" aria-hidden="true">
									<span class="theme-tile-card">
										<span class="theme-tile-bar"></span>
										<span class="theme-tile-line"></span>
										<span class="theme-tile-line theme-tile-line-short"></span>
									</span>
								</span>
								<span class="theme-tile-row">
									<span class="theme-tile-name">{t.name}</span>
									<svg class="theme-tile-check" aria-hidden="true" viewBox="0 0 24 24">
										<path d="M20 6 9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
									</svg>
								</span>
							</button>
						))}
					</div>
				</div>
			</div>
			<button class="mobile-menu-toggle" type="button" data-mobile-menu-toggle aria-label="Open menu" aria-expanded="false">
				<svg class="mobile-menu-icon" aria-hidden="true" viewBox="0 0 24 24">
					<path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" />
				</svg>
				<svg class="mobile-close-icon" aria-hidden="true" viewBox="0 0 24 24">
					<path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" />
				</svg>
			</button>
			<div class="mobile-menu" data-mobile-menu>
				<div class="mobile-menu-card">
					<div class="mobile-menu-head">
						<span>Menu</span>
						<button type="button" data-mobile-search-open aria-label="Search documentation">
							<svg aria-hidden="true" viewBox="0 0 24 24">
								<path d="m20 20-4.35-4.35m2.35-5.15a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" />
							</svg>
						</button>
					</div>
					<a href={withBase('/docs/')}>Docs</a>
					<a href={withBase('/blog/')}>Blog</a>
					<a href={withBase(navGroups[0].items[0].href)}>Get Started</a>
					<a href={siteConfig.githubUrl} target="_blank">
						<GitHubIcon />
						GitHub
					</a>
					{githubSponsorsUrl && (
						<a class="nav-heart" href={githubSponsorsUrl} target="_blank">
							<HeartIcon />
							Support
						</a>
					)}
				</div>
			</div>
		</header>
		<div class="mobile-backdrop" data-mobile-backdrop data-pagefind-ignore></div>
		<main data-pagefind-body>
			<slot />
		</main>
		<footer class="site-footer" data-pagefind-ignore>
			<div class="footer-divider"></div>
			<div class="footer-inner">
				<div class="footer-brand">
					<Logo class="footer-logo" />
					<strong>{siteConfig.name}</strong>
					<span>{siteConfig.tagline}</span>
				</div>
				<nav class="footer-nav" aria-label="Footer navigation">
					{quickLinks.slice(0, 4).map((link) => <a href={withBase(link.href)}>{link.title}</a>)}
				</nav>
				<div class="footer-actions">
					<a href={withBase('/blog/')}>Blog</a>
					{githubSponsorsUrl && (
						<a class="nav-heart" href={githubSponsorsUrl} target="_blank">
							<HeartIcon />
							Support
						</a>
					)}
					<a class="icon-link" href={siteConfig.githubUrl} target="_blank">
						<GitHubIcon />
						GitHub
					</a>
				</div>
				<p class="footer-meta">
					&copy; {new Date().getFullYear()}{' '}
					<a href={siteConfig.authorUrl} target="_blank">{siteConfig.author}</a>
				</p>
			</div>
		</footer>
		<script is:inline>
			(() => {
				const KEY = 'theme';
				const root = document.documentElement;
				const picker = document.querySelector('[data-theme-picker]');
				const quickToggle = document.querySelector('[data-theme-quick-toggle]');
				const menuToggle = document.querySelector('[data-theme-menu-toggle]');
				const popover = document.querySelector('[data-theme-popover]');
				if (!picker || !quickToggle || !menuToggle || !popover) return;

				const modeOf = (id) => (id.endsWith('-dark') ? 'dark' : 'light');
				const familyOf = (id) => id.replace(/-(light|dark)$/, '');
				const siblingExists = (id) => !!document.querySelector(`[data-theme-id="${id}"]`);

				const readStored = () => localStorage.getItem(KEY);
				const isSystem = () => {
					const s = readStored();
					return !s || s === 'system';
				};
				const effective = () => {
					const s = readStored();
					if (!s || s === 'system') {
						return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'flect-dark' : 'flect-light';
					}
					return s;
				};

				function apply(id) {
					const mode = modeOf(id);
					root.dataset.mode = mode;
					root.dataset.theme = id;
					quickToggle.setAttribute('aria-pressed', String(mode === 'dark'));
					renderActiveStates();
				}

				function persist(id) {
					localStorage.setItem(KEY, id);
					apply(id);
				}

				function useSystem() {
					localStorage.setItem(KEY, 'system');
					apply(effective());
				}

				function toggleQuick() {
					if (isSystem()) {
						const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
						persist(dark ? 'flect-light' : 'flect-dark');
						return;
					}
					const current = effective();
					const other = modeOf(current) === 'dark' ? 'light' : 'dark';
					const sibling = `${familyOf(current)}-${other}`;
					persist(siblingExists(sibling) ? sibling : `flect-${other}`);
				}

				function renderActiveStates() {
					const current = effective();
					const system = isSystem();
					const mode = modeOf(current);
					popover.querySelectorAll('[data-theme-segment]').forEach((btn) => {
						const seg = btn.dataset.themeSegment;
						const active = system ? seg === 'system' : seg === mode;
						btn.classList.toggle('active', active);
					});
					popover.querySelectorAll('.theme-tile').forEach((tile) => {
						const active = !system && tile.dataset.themeId === current;
						tile.classList.toggle('active', active);
						tile.setAttribute('aria-checked', String(active));
					});
					popover.querySelectorAll('[data-mode-grid]').forEach((grid) => {
						grid.hidden = grid.dataset.modeGrid !== mode;
					});
				}

				function openPopover() {
					popover.hidden = false;
					menuToggle.setAttribute('aria-expanded', 'true');
					renderActiveStates();
					document.addEventListener('pointerdown', onDocPointer, true);
					document.addEventListener('keydown', onKeydown);
				}
				function closePopover() {
					popover.hidden = true;
					menuToggle.setAttribute('aria-expanded', 'false');
					document.removeEventListener('pointerdown', onDocPointer, true);
					document.removeEventListener('keydown', onKeydown);
				}
				function onDocPointer(e) {
					if (picker.contains(e.target)) return;
					closePopover();
				}
				function onKeydown(e) {
					if (e.key === 'Escape') closePopover();
				}

				quickToggle.addEventListener('click', toggleQuick);
				menuToggle.addEventListener('click', () => {
					popover.hidden ? openPopover() : closePopover();
				});
				popover.querySelectorAll('[data-theme-segment]').forEach((btn) => {
					btn.addEventListener('click', () => {
						const seg = btn.dataset.themeSegment;
						if (seg === 'system') {
							useSystem();
							return;
						}
						const current = effective();
						const family = isSystem() ? 'flect' : familyOf(current);
						const id = `${family}-${seg}`;
						persist(siblingExists(id) ? id : `flect-${seg}`);
					});
				});
				popover.querySelectorAll('.theme-tile').forEach((tile) => {
					tile.addEventListener('click', () => {
						persist(tile.dataset.themeId);
						closePopover();
					});
				});

				window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
					if (isSystem()) apply(effective());
				});

				apply(effective());
			})();
		</script>
		<script is:inline>
			(() => {
				const blocks = document.querySelectorAll('main pre');
				for (const pre of blocks) {
					if (pre.closest('.prompt-player') || pre.parentElement?.classList.contains('code-frame')) {
						continue;
					}

					const frame = document.createElement('div');
					frame.className = 'code-frame';
					const button = document.createElement('button');
					button.className = 'copy-code-button';
					button.type = 'button';
					button.textContent = 'Copy';
					button.setAttribute('aria-label', 'Copy code block');

					pre.parentNode?.insertBefore(frame, pre);
					frame.append(pre, button);

					button.addEventListener('click', async () => {
						const text = pre.textContent || '';
						try {
							await navigator.clipboard.writeText(text);
							button.textContent = 'Copied';
							window.setTimeout(() => {
								button.textContent = 'Copy';
							}, 1300);
						} catch {
							button.textContent = 'Failed';
							window.setTimeout(() => {
								button.textContent = 'Copy';
							}, 1300);
						}
					});
				}
			})();

			(() => {
				const header = document.querySelector('.site-header');
				if (!header) return;
				let lastY = window.scrollY;
				let ticking = false;

				const update = () => {
					const y = window.scrollY;
					if (header.classList.contains('menu-open')) {
						lastY = y;
						ticking = false;
						return;
					}
					if (y <= 60) {
						header.classList.remove('header-hidden');
					} else if (y > lastY) {
						header.classList.add('header-hidden');
					} else {
						header.classList.remove('header-hidden');
					}
					lastY = y;
					ticking = false;
				};

				window.addEventListener('scroll', () => {
					if (!ticking) {
						requestAnimationFrame(update);
						ticking = true;
					}
				}, { passive: true });
			})();

			(() => {
				const header = document.querySelector('.site-header');
				const toggle = document.querySelector('[data-mobile-menu-toggle]');
				const backdrop = document.querySelector('[data-mobile-backdrop]');
				const menu = document.querySelector('[data-mobile-menu]');
				const search = document.querySelector('[data-mobile-search-open]');
				const closeMenu = () => {
					header?.classList.remove('menu-open');
					toggle?.setAttribute('aria-expanded', 'false');
				};
				const openMenu = () => {
					header?.classList.add('menu-open');
					toggle?.setAttribute('aria-expanded', 'true');
				};

				toggle?.addEventListener('click', () => {
					header?.classList.contains('menu-open') ? closeMenu() : openMenu();
				});
				backdrop?.addEventListener('click', closeMenu);
				menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
				search?.addEventListener('click', () => {
					closeMenu();
					document.dispatchEvent(new CustomEvent('docs:open-search'));
				});
				document.addEventListener('keydown', (event) => {
					if (event.key === 'Escape') closeMenu();
				});
			})();
		</script>
	</body>
</html>
