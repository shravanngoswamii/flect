---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { withBase } from "../lib/paths";
import { slugifyTag } from "../utils/slug";

type BlogData = CollectionEntry<"blog">["data"];

interface Props {
	href: string;
	title: BlogData["title"];
	description: BlogData["description"];
	pubDate: BlogData["pubDate"];
	tags?: BlogData["tags"];
	heroImage?: BlogData["heroImage"];
	readingMinutes: number;
	featured?: boolean;
}

const {
	href,
	title,
	description,
	pubDate,
	tags,
	heroImage,
	readingMinutes,
	featured = false,
} = Astro.props;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

// The first tag doubles as the row's category label; the rest stay
// discoverable from the post page itself rather than crowding the listing.
const [eyebrow] = tags ?? [];
---

<article class:list={["blog-card", { featured }]}>
	{
		heroImage && (
			<a class="blog-card-thumb" href={href} tabindex="-1" aria-hidden="true">
				{typeof heroImage === "string" ? (
					<img src={heroImage} alt="" loading={featured ? "eager" : "lazy"} />
				) : (
					<Image
						src={heroImage}
						alt=""
						widths={featured ? [640, 960, 1280] : [320, 640]}
						sizes={featured ? "(min-width: 720px) 34rem, 100vw" : "(min-width: 720px) 16rem, 100vw"}
						loading={featured ? "eager" : "lazy"}
					/>
				)}
			</a>
		)
	}
	<div class="blog-card-body">
		{
			(featured || eyebrow) && (
				<div class="blog-card-eyebrow-row">
					{featured && <span class="blog-card-latest">Latest</span>}
					{eyebrow && (
						<a class="blog-card-eyebrow" href={withBase(`/blog/tags/${slugifyTag(eyebrow)}/`)}>
							{eyebrow}
						</a>
					)}
				</div>
			)
		}
		<h2 class="blog-card-title">
			<a href={href}>{title}</a>
		</h2>
		<p class="blog-card-description">{description}</p>
		<div class="blog-card-meta">
			<time datetime={pubDate.toISOString()}>{dateFormatter.format(pubDate)}</time>
			<span class="blog-card-reading-time">{readingMinutes} min read</span>
			<span class="blog-card-cta" aria-hidden="true">
				Read post
				<svg viewBox="0 0 24 24">
					<path d="M5 12h14m-6-6 6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</span>
		</div>
	</div>
</article>
