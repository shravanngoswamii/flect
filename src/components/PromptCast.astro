---
import "asciinema-player/dist/bundle/asciinema-player.css";
---

<div class="prompt-player" data-prompt-player aria-label="Flect quick start terminal recording"></div>

<script>
	import { create } from 'asciinema-player';

	const target = document.querySelector('[data-prompt-player]');
	if (target) {
		const base = import.meta.env.BASE_URL || '/';
		const normalizedBase = base.endsWith('/') ? base.slice(0, -1) : base;
		const castPath = `${normalizedBase}/casts/quickstart.cast`;

		const player = create(castPath, target, {
			autoplay: true,
			preload: true,
			loop: false,
			speed: 1.0,
			idleTimeLimit: 1.2,
			cols: 82,
			rows: 10,
			fit: 'width',
			theme: 'asciinema',
		}) as unknown as {
			addEventListener: (event: string, cb: () => void) => void;
			seek: (pos: number) => Promise<void>;
			play: () => Promise<void>;
		};

		player.addEventListener('ended', () => {
			setTimeout(() => {
				player.seek(0).then(() => player.play());
			}, 2000);
		});
	}
</script>
